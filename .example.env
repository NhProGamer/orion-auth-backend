# OrionAuth Configuration
# Copy to .env and adjust values for your environment.
# All variables use the ORION_ prefix with UPPER_SNAKE_CASE.

# ── Server ───────────────────────────────────────────────
ORION_SERVER_HOST=0.0.0.0
ORION_SERVER_PORT=8080
ORION_SERVER_MODE=release    # debug, release, test

# ── Database (PostgreSQL) ────────────────────────────────
ORION_DATABASE_HOST=localhost
ORION_DATABASE_PORT=5432
ORION_DATABASE_USER=orionauth
ORION_DATABASE_PASSWORD=orionauth
ORION_DATABASE_NAME=orionauth
ORION_DATABASE_SSLMODE=disable
ORION_DATABASE_MAX_OPEN_CONNS=25
ORION_DATABASE_MAX_IDLE_CONNS=10
ORION_DATABASE_CONN_MAX_LIFETIME=5m

# ── Auth ─────────────────────────────────────────────────
ORION_AUTH_ACCESS_TOKEN_TTL=1h
ORION_AUTH_REFRESH_TOKEN_TTL=24h
ORION_AUTH_SESSION_TTL=720h
ORION_AUTH_AUTH_CODE_TTL=60s
ORION_AUTH_DEVICE_CODE_TTL=10m
ORION_AUTH_PASSWORD_MIN_LENGTH=8
ORION_AUTH_MAX_FAILED_ATTEMPTS=5
ORION_AUTH_LOCKOUT_DURATION=15m

# ── Argon2 (password hashing) ───────────────────────────
ORION_ARGON2_MEMORY=65536       # KiB (64 MB)
ORION_ARGON2_ITERATIONS=3
ORION_ARGON2_PARALLELISM=4
ORION_ARGON2_SALT_LENGTH=16
ORION_ARGON2_KEY_LENGTH=32

# ── CORS ─────────────────────────────────────────────────
ORION_CORS_ALLOWED_ORIGINS=http://localhost:3000
ORION_CORS_ALLOWED_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
ORION_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
ORION_CORS_MAX_AGE=3600

# ── SMTP ─────────────────────────────────────────────────
ORION_SMTP_HOST=localhost
ORION_SMTP_PORT=1025
ORION_SMTP_USERNAME=
ORION_SMTP_PASSWORD=
ORION_SMTP_FROM=noreply@orionauth.local
ORION_SMTP_FROM_NAME=OrionAuth
ORION_SMTP_TLS=false

# ── Issuer ───────────────────────────────────────────────
ORION_ISSUER=http://localhost:8080
