<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset your password</title>
<!--[if mso]><style>table,td{font-family:Arial,sans-serif!important;}</style><![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#0a0a0b;-webkit-text-size-adjust:none;">
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0a0a0b;padding:40px 0;">
  <tr>
    <td align="center">
      <table width="520" cellpadding="0" cellspacing="0" border="0" style="background-color:#111113;border:1px solid #1e1e22;border-radius:12px;overflow:hidden;">

        <!-- LOGO -->
        <tr>
          <td style="padding:24px 32px;border-bottom:1px solid #1e1e22;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="width:8px;height:8px;background-color:#7f77dd;border-radius:50;"></td>
                <td style="padding-left:10px;font-family:'JetBrains Mono',Menlo,Consolas,monospace;font-size:16px;font-weight:600;color:#e8e8e8;letter-spacing:-0.02em;">OrionAuth</td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- CONTENT -->
        <tr>
          <td style="padding:36px 32px 32px;">
            <h2 style="margin:0 0 8px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:20px;font-weight:600;color:#e8e8e8;letter-spacing:-0.03em;">Password Reset</h2>
            <p style="margin:0 0 28px;font-family:'Helvetica Neue',Arial,sans-serif;font-size:14px;line-height:1.6;color:#6b6b78;">You requested a password reset. Click the button below to set a new password.</p>

            <!-- CTA BUTTON -->
            <table cellpadding="0" cellspacing="0" border="0" style="margin:0 0 28px;">
              <tr>
                <td style="background-color:#7f77dd;border-radius:8px;">
                  <a href="{{.Issuer}}/ui/reset-password?token={{.Token}}" target="_blank" style="display:inline-block;padding:12px 28px;font-family:'JetBrains Mono',Menlo,Consolas,monospace;font-size:13px;font-weight:500;color:#ffffff;text-decoration:none;">Reset your password</a>
                </td>
              </tr>
            </table>

            <p style="margin:0 0 6px;font-family:'JetBrains Mono',Menlo,Consolas,monospace;font-size:11px;color:#6b6b78;">This link expires in 1 hour.</p>
            <p style="margin:0;font-family:'Helvetica Neue',Arial,sans-serif;font-size:13px;color:#6b6b78;">If you didn't request this, you can safely ignore this email.</p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td style="padding:20px 32px;border-top:1px solid #1e1e22;">
            <p style="margin:0;font-family:'JetBrains Mono',Menlo,Consolas,monospace;font-size:11px;color:#3a3a44;">Sent by OrionAuth</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
</body>
</html>
