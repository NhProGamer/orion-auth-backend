<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="dark light">
<meta name="supported-color-schemes" content="dark light">
<title>Reset your password</title>
<!--[if mso]><style>table,td{font-family:Arial,sans-serif!important;}</style><![endif]-->
<style>
  @media (prefers-color-scheme: light) {
    .body { background-color: #fafafb !important; }
    .card { background-color: #ffffff !important; border-color: #e8e8eb !important; }
    .divider { border-color: #e8e8eb !important; }
    .fg-0 { color: #26252e !important; }
    .fg-2 { color: #6d6c77 !important; }
    .fg-3 { color: #8d8c95 !important; }
    .brand-orion { color: #26252e !important; }
    .logo-dark { display: none !important; }
    .logo-light { display: inline-block !important; }
  }
</style>
</head>
<body class="body" style="margin:0;padding:0;background-color:#1c1b22;-webkit-text-size-adjust:none;">
<table width="100%" cellpadding="0" cellspacing="0" border="0" class="body" style="background-color:#1c1b22;padding:40px 16px;">
  <tr>
    <td align="center">
      <table width="520" cellpadding="0" cellspacing="0" border="0" class="card" style="background-color:#232229;border:1px solid #363641;border-radius:12px;overflow:hidden;max-width:520px;width:100%;">

        <!-- HEADER -->
        <tr>
          <td class="divider" style="padding:24px 32px;border-bottom:1px solid #363641;">
            <table cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="vertical-align:middle;padding-right:12px;">
                  <img class="logo-dark" src="{{.Issuer}}/email-assets/logo-dark.svg" alt="" width="32" height="32" style="display:block;width:32px;height:32px;border:0;" />
                  <img class="logo-light" src="{{.Issuer}}/email-assets/logo-light.svg" alt="" width="32" height="32" style="display:none;width:32px;height:32px;border:0;" />
                </td>
                <td style="vertical-align:middle;font-family:'Instrument Serif',Georgia,'Times New Roman',serif;font-size:22px;font-weight:400;letter-spacing:-0.01em;line-height:1;">
                  <span class="brand-orion fg-0" style="color:#f5f5f6;">orion</span><span style="color:#9b85f4;">auth</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- CONTENT -->
        <tr>
          <td style="padding:36px 32px 32px;">
            <h1 class="fg-0" style="margin:0 0 12px;font-family:'Inter',-apple-system,'Helvetica Neue',Arial,sans-serif;font-size:22px;font-weight:600;color:#f5f5f6;letter-spacing:-0.02em;line-height:1.3;">Reset your password</h1>
            <p class="fg-2" style="margin:0 0 28px;font-family:'Inter',-apple-system,'Helvetica Neue',Arial,sans-serif;font-size:14px;line-height:1.6;color:#9a9aa1;">You requested a password reset. Click the button below to choose a new password.</p>

            <!-- CTA -->
            <table cellpadding="0" cellspacing="0" border="0" style="margin:0 0 28px;">
              <tr>
                <td style="background-color:#9b85f4;border-radius:8px;">
                  <a href="{{.Issuer}}/ui/reset-password?token={{.Token}}" target="_blank" style="display:inline-block;padding:12px 28px;font-family:'Inter',-apple-system,'Helvetica Neue',Arial,sans-serif;font-size:14px;font-weight:500;color:#ffffff;text-decoration:none;letter-spacing:-0.01em;">Reset your password</a>
                </td>
              </tr>
            </table>

            <p class="fg-3" style="margin:0 0 8px;font-family:'JetBrains Mono',Menlo,Consolas,monospace;font-size:11px;color:#76757b;letter-spacing:0.02em;">This link expires in 1 hour.</p>
            <p class="fg-2" style="margin:0;font-family:'Inter',-apple-system,'Helvetica Neue',Arial,sans-serif;font-size:13px;line-height:1.5;color:#9a9aa1;">If you didn't request this, you can safely ignore this email.</p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td class="divider" style="padding:20px 32px;border-top:1px solid #363641;">
            <p class="fg-3" style="margin:0;font-family:'JetBrains Mono',Menlo,Consolas,monospace;font-size:11px;color:#76757b;letter-spacing:0.02em;">Sent by OrionAuth</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
</body>
</html>
